<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mybaits.mapper"> <!-- com.spring.mugpet.dao.mybatis.mapper로 경로 변경해야함 = interface랑 경로 일치시키는 게 좋음 -->
	<cache />
	<sql id="itemCols">
		item_id, category_id,
		itemName, price, brand,
		imgURL, comments, filter
	</sql>
	
	<select id="getItem" parameterType="com.spring.mugpet.domain.Item">
		SELECT <include refid="itemCols" />
		FROM Item
		WHERE item_id=#{item_id}
	</select>
	
	<select id="getItemList" parameterType="com.spring.mugpet.domain.Item">
		SELECT <include refid="itemCols" />
		FROM Item
		WHERE category_id=#{category_id}
	</select>
	
	<select id="getALLItemList" parameterType="com.spring.mugpet.domain.Item">
		SELECT <include refid="itemCols" />
		FROM Item
	</select>
	
	<select id="getSearchItemList"  parameterType="com.spring.mugpet.domain.Item">
		SELECT <include refid="itemCols" />
		FROM Item
		WHERE filter=#{filter}
	</select>
	
	<insert id="insertItem" parameterType="com.spring.mugpet.domain.Item">
		INSERT INTO Item (<include refid="itemCols" />)
		VALUES (#{item_id}, #{category_id}, #{itemName}, #{price}, #{brand}, #{imgURL}, #{filter})
	</insert>
	
	<update id="updateItem" parameterType="com.spring.mugpet.domain.Item">
		UPDATE Item
		SET category_id=#{category_id},
		itemName=#{ItemName},
		price=#{price},
		brand=#{brand},
		imgURL=#{imgURL},
		comments=#{comments},
		filter=#{filter}
		WHERE item_id=#{item_id}
	</update>
		
	<delete id="deleteItem" parameterType="com.spring.mugpet.domain.Item">
		DELETE FROM Item
		WHERE item_id=#{item_id}
	</delete>
</mapper>